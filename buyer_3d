<!DOCTYPE html>
<html lang="am">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>የገዢ ማሳያ - 3D ሱቅ</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        body {
            margin: 0;
            padding: 0;
            overflow: hidden; /* ምንም አይነት ስክሮል እንዳይኖር */
            background-color: #0b0f19; /* ከዋናው ሲስተም ጋር የሚመሳሰል ባክግራውንድ */
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #f1f5f9;
        }

        #canvas-container {
            width: 100vw;
            height: 100vh;
            position: absolute;
            top: 0;
            left: 0;
            z-index: 1;
        }

        /* የገዢው ገጽ ላይ የሚታዩ ፅሁፎች እና መረጃዎች (UI) */
        .ui-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 10;
            pointer-events: none; /* ማውሱ 3Dውን እንዲያዞረው የUI ንክኪን እናጠፋለን */
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 30px;
            box-sizing: border-box;
        }

        .header {
            text-align: center;
            background: rgba(21, 31, 50, 0.6);
            backdrop-filter: blur(10px);
            padding: 15px 30px;
            border-radius: 20px;
            border: 1px solid rgba(56, 189, 248, 0.2);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
            display: inline-block;
            margin: 0 auto;
            pointer-events: auto;
        }

        .header h1 {
            margin: 0;
            font-size: 2rem;
            color: #38bdf8;
            letter-spacing: 2px;
        }

        .header p {
            margin: 5px 0 0 0;
            color: #94a3b8;
            font-size: 0.9rem;
        }

        .product-info {
            background: rgba(21, 31, 50, 0.6);
            backdrop-filter: blur(10px);
            padding: 25px;
            border-radius: 15px;
            border-left: 4px solid #4ade80;
            max-width: 350px;
            pointer-events: auto;
            transition: transform 0.3s ease;
        }

        .product-info:hover {
            transform: scale(1.05);
        }

        .product-info h2 {
            margin: 0 0 10px 0;
            color: #f1f5f9;
        }

        .price-tag {
            font-size: 1.8rem;
            color: #4ade80;
            font-weight: bold;
            margin-bottom: 15px;
        }

        .btn-back {
            display: inline-block;
            background: #38bdf8;
            color: #0b0f19;
            padding: 10px 20px;
            text-decoration: none;
            font-weight: bold;
            border-radius: 8px;
            transition: background 0.3s;
            pointer-events: auto;
        }

        .btn-back:hover {
            background: #f1f5f9;
        }

        .instructions {
            position: absolute;
            bottom: 30px;
            width: 100%;
            text-align: center;
            color: #94a3b8;
            font-size: 0.85rem;
            animation: pulse-glow 2s infinite;
        }

        @keyframes pulse-glow { 
            0% { opacity: 0.6; } 
            50% { opacity: 1; } 
            100% { opacity: 0.6; } 
        }
    </style>
</head>
<body>

    <div id="canvas-container"></div>

    <div class="ui-layer">
        <div style="display: flex; justify-content: space-between; width: 100%;">
            <a href="index.html" class="btn-back">⬅ ወደ ዋናው ገጽ ተመለስ</a>
            <div class="header">
                <h1>ዘመናዊ እይታ</h1>
                <p>ምርቶቻችንን በ3D ይቃኙ</p>
            </div>
            <div style="width: 150px;"></div> </div>

        <div class="product-info">
            <h2>ልዩ እና ዘመናዊ እቃ</h2>
            <div class="price-tag">አዲስ ገቢ</div>
            <p style="color: #cbd5e1; font-size: 0.95rem; line-height: 1.5;">
                ይህ የገዢዎች ማሳያ ገጽ ነው። እቃውን በየአቅጣጫው ለማየት ማውስዎን ይንኩ እና ያንቀሳቅሱ። ዘመኑን የጠበቀ አቀራረብ!
            </p>
        </div>

        <div class="instructions">
            [ ማውስዎን በመጫን 3D ሞዴሉን ያሽከርክሩ ]
        </div>
    </div>

    <script>
        // የ3D ማዘጋጃ (Scene Setup)
        const scene = new THREE.Scene();
        // የጀርባ ቀለም ከስርአትህ ጋር ተመሳሳይ #0b0f19
        scene.background = new THREE.Color(0x0b0f19); 
        scene.fog = new THREE.FogExp2(0x0b0f19, 0.0015); // አሪፍ የጭጋግ ኢፌክት

        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ antialias: true });
        
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(window.devicePixelRatio);
        document.getElementById('canvas-container').appendChild(renderer.domElement);

        // ዘመናዊ የሚንቀሳቀስ የ3D እቃ (TorusKnot - ውስብስብ እና የሚያምር ቅርፅ)
        const geometry = new THREE.TorusKnotGeometry(10, 3, 200, 32);
        
        // የእቃው ማቴሪያል (የሚያብረቀርቅ እና ብርሃን የሚቀበል)
        const material = new THREE.MeshStandardMaterial({ 
            color: 0x38bdf8, 
            metalness: 0.7, 
            roughness: 0.2,
            wireframe: false
        });
        
        const mainObject = new THREE.Mesh(geometry, material);
        scene.add(mainObject);

        // በዙሪያው የሚንሳፈፉ ትንንሽ እቃዎች (Particles) መፍጠሪያ
        const particlesGeometry = new THREE.BufferGeometry();
        const particlesCount = 700;
        const posArray = new Float32Array(particlesCount * 3);

        for(let i = 0; i < particlesCount * 3; i++) {
            // በዘፈቀደ የተበተኑ ነጥቦች
            posArray[i] = (Math.random() - 0.5) * 100;
        }

        particlesGeometry.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
        const particlesMaterial = new THREE.PointsMaterial({
            size: 0.2,
            color: 0x4ade80,
            transparent: true,
            opacity: 0.8
        });

        const particlesMesh = new THREE.Points(particlesGeometry, particlesMaterial);
        scene.add(particlesMesh);

        // መብራት (Lighting) - 3D ሆኖ እንዲታይ ወሳኝ ነው
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
        scene.add(ambientLight);

        const pointLight1 = new THREE.PointLight(0x38bdf8, 2, 100);
        pointLight1.position.set(20, 20, 20);
        scene.add(pointLight1);

        const pointLight2 = new THREE.PointLight(0xc084fc, 2, 100);
        pointLight2.position.set(-20, -20, 20);
        scene.add(pointLight2);

        camera.position.z = 30;

        // የማውስ እንቅስቃሴ መቆጣጠሪያ
        let mouseX = 0;
        let mouseY = 0;
        let targetX = 0;
        let targetY = 0;

        const windowHalfX = window.innerWidth / 2;
        const windowHalfY = window.innerHeight / 2;

        document.addEventListener('mousemove', (event) => {
            mouseX = (event.clientX - windowHalfX);
            mouseY = (event.clientY - windowHalfY);
        });

        // ስክሪኑ ሲሰፋና ሲጠብ ካሜራውን ማስተካከል
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        // አኒሜሽን (Animation Loop) - ያለማቋረጥ እንዲንቀሳቀስ
        const clock = new THREE.Clock();

        function animate() {
            requestAnimationFrame(animate);
            const elapsedTime = clock.getElapsedTime();

            // ዋናው እቃ በራሱ ጊዜ እንዲሽከረከር
            mainObject.rotation.y += 0.005;
            mainObject.rotation.x += 0.002;
            
            // ዋናው እቃ ወደላይ እና ወደታች እንዲንሳፈፍ
            mainObject.position.y = Math.sin(elapsedTime * 1) * 2;

            // ትንንሽ ነጥቦቹ ቀስ ብለው እንዲሽከረከሩ
            particlesMesh.rotation.y = -elapsedTime * 0.05;
            particlesMesh.rotation.x = elapsedTime * 0.02;

            // ማውስ ሲንቀሳቀስ ካሜራው ምላሽ እንዲሰጥ
            targetX = mouseX * 0.001;
            targetY = mouseY * 0.001;
            
            mainObject.rotation.y += 0.05 * (targetX - mainObject.rotation.y);
            mainObject.rotation.x += 0.05 * (targetY - mainObject.rotation.x);

            renderer.render(scene, camera);
        }

        animate();
    </script>
</body>
</html>

